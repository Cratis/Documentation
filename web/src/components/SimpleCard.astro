---
// A clickable feature card: a boxed accent icon, a title, and a short body.
// Used on the splash homepage's "Why developers choose Cratis" grid — the
// aspire.dev SimpleCard pattern, in Cratis colors.
import { Icon } from '@astrojs/starlight/components';

interface Props {
    title: string;
    icon: string;
    link: string;
}

const { title, icon, link } = Astro.props;
---

<a href={link} class="cratis-feature-card">
    <span class="cratis-feature-card__icon">
        <Icon name={icon} size="1.4rem" />
    </span>
    <span class="cratis-feature-card__title">{title}</span>
    <span class="cratis-feature-card__body"><slot /></span>
</a>

<style>
    .cratis-feature-card {
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
        padding: 1.25rem;
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 0.75rem;
        background: var(--sl-color-bg);
        text-decoration: none;
        color: var(--sl-color-text);
        transition: border-color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
    }
    .cratis-feature-card:hover {
        border-color: var(--sl-color-accent);
        transform: translateY(-3px);
        box-shadow: 0 10px 28px -16px var(--sl-color-accent);
    }
    .cratis-feature-card__icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.55rem;
        border-radius: 0.6rem;
        color: var(--sl-color-accent-high);
        background: color-mix(in srgb, var(--sl-color-accent) 14%, transparent);
        border: 1px solid color-mix(in srgb, var(--sl-color-accent) 30%, transparent);
    }
    .cratis-feature-card:hover .cratis-feature-card__icon {
        background: var(--sl-color-accent);
        border-color: var(--sl-color-accent);
        color: var(--sl-color-text-invert);
    }
    .cratis-feature-card__title {
        font-size: var(--sl-text-lg);
        font-weight: 600;
        line-height: 1.2;
        color: var(--sl-color-white);
    }
    .cratis-feature-card__body {
        font-size: var(--sl-text-sm);
        line-height: 1.5;
        color: var(--sl-color-gray-2);
    }
</style>
