---
// Embeds the statically-built Component Storybook (hosted under <base>/storybook/).
// Build it with `npm run build:storybook` (writes to web/public/storybook, git-ignored),
// or rely on the docs-site CI workflow which builds it before the Astro build.
interface Props {
  /** Which static Storybook to embed, as a site-root path. Defaults to the Components storybook. */
  storybook?: string;
  /** Deep-link into a specific story, e.g. "/story/commanddialog--default". Optional. */
  path?: string;
  /** iframe height (CSS length). */
  height?: string;
  /** Accessible iframe title. */
  title?: string;
}
const { storybook = '/storybook', path = '', height = '820px', title = 'Cratis Storybook' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const storybookRoot = `${base}${storybook.replace(/\/$/, '')}`;

function normalizeStoryPath(value: string) {
  const clean = value.trim();
  if (!clean) return '';
  if (clean.startsWith('/story/') || clean.startsWith('/docs/')) return clean;
  if (clean.startsWith('story/') || clean.startsWith('docs/')) return `/${clean}`;
  return `/story/${clean}`;
}

function buildStorybookSrc(root: string, storyPath: string) {
  const params = new URLSearchParams();
  if (storyPath) {
    // Match the old DocFX embed: focused story, docs/controls panel open, Storybook nav hidden.
    params.set('nav', 'false');
    params.set('panel', 'right');
    params.set('addonPanel', 'storybook/docs');
    params.set('path', storyPath);
  }
  const query = params.toString();
  return `${root}/index.html${query ? `?${query}` : ''}`;
}

const initialStoryPath = normalizeStoryPath(path);
const src = buildStorybookSrc(storybookRoot, initialStoryPath);
---

<div
  class="storybook-embed"
  data-storybook-embed
  data-storybook-root={storybookRoot}
  data-storybook-path={initialStoryPath}
  style={`--sb-height:${height}`}
>
  <div class="storybook-embed__bar">
    <a href={src} target="_blank" rel="noopener">Open full screen ↗</a>
  </div>
  <iframe src={src} title={title} loading="lazy"></iframe>
</div>

<script>
  const normalizeStoryPath = (value) => {
    const clean = (value || '').trim();
    if (!clean) return '';
    if (clean.startsWith('/story/') || clean.startsWith('/docs/')) return clean;
    if (clean.startsWith('story/') || clean.startsWith('docs/')) return `/${clean}`;
    return `/story/${clean}`;
  };

  const buildStorybookSrc = (root, storyPath) => {
    const url = new URL(`${root}/index.html`, window.location.origin);
    if (storyPath) {
      url.searchParams.set('nav', 'false');
      url.searchParams.set('panel', 'right');
      url.searchParams.set('addonPanel', 'storybook/docs');
      url.searchParams.set('path', storyPath);
    }
    return `${url.pathname}${url.search}`;
  };

  const getTheme = () => document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';

  for (const embed of document.querySelectorAll('[data-storybook-embed]')) {
    const iframe = embed.querySelector('iframe');
    const link = embed.querySelector('a');
    const root = embed.dataset.storybookRoot;
    if (!iframe || !link || !root) continue;

    const params = new URLSearchParams(window.location.search);
    const story = params.get('story');
    const requestedPath = story
      ? `/story/${story.replace(/^\/?story\//, '')}`
      : params.get('path') || embed.dataset.storybookPath || '';
    const storyPath = normalizeStoryPath(requestedPath);
    const src = buildStorybookSrc(root, storyPath);

    iframe.src = src;
    link.href = src;

    const syncTheme = () => {
      iframe.contentWindow?.postMessage({ type: 'STORYBOOK_THEME_CHANGE', theme: getTheme() }, '*');
    };

    iframe.addEventListener('load', () => {
      setTimeout(syncTheme, 100);
    });

    new MutationObserver(syncTheme).observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });
  }
</script>

<style>
  .storybook-embed {
    margin: 1.5rem 0;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    overflow: hidden;
    background: var(--sl-color-gray-7, var(--sl-color-gray-6));
  }
  .storybook-embed__bar {
    display: flex;
    justify-content: flex-end;
    padding: 0.4rem 0.6rem;
    border-bottom: 1px solid var(--sl-color-gray-5);
    font-size: var(--sl-text-xs);
  }
  .storybook-embed iframe {
    display: block;
    width: 100%;
    height: var(--sb-height);
    border: 0;
  }
</style>
