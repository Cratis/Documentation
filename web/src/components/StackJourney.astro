---
import { Icon } from '@astrojs/starlight/components';

interface Props {
    eyebrow?: string;
    title?: string;
    intro?: string;
}

const {
    eyebrow = 'Stack journey',
    title = 'Follow one feature through the stack',
    intro = 'A Cratis feature moves from model to code, from event to read model, from generated proxy to React, and then back into the tools that help you operate it.',
} = Astro.props;

const steps = [
    {
        phase: 'Model',
        product: 'Studio',
        icon: 'open-book',
        title: 'Map the domain first',
        description: 'Capture the command, event, read model, and team intent before the implementation spreads out.',
        href: '/studio/',
        cta: 'Open Studio',
        accent: '#f59e0b',
    },
    {
        phase: 'Build',
        product: 'Arc',
        icon: 'puzzle',
        title: 'Keep the slice together',
        description: 'Put the command, handler, query, proxy, and UI for one behavior in one feature-shaped place.',
        href: '/arc/vertical-slices/',
        cta: 'See vertical slices',
        accent: '#38bdf8',
    },
    {
        phase: 'Secure',
        product: 'AuthProxy',
        icon: 'seti:lock',
        title: 'Resolve identity and tenant',
        description: 'Authenticate once, resolve the tenant, enrich identity, and let services receive trusted context.',
        href: '/authproxy/',
        cta: 'Explore AuthProxy',
        accent: '#f97316',
    },
    {
        phase: 'Record',
        product: 'Chronicle',
        icon: 'seti:db',
        title: 'Store what happened',
        description: 'Append facts through Chronicle\'s gRPC boundary and let projections turn them into read models on the storage backend you chose.',
        href: '/chronicle/',
        cta: 'Explore Chronicle',
        accent: '#4ade80',
    },
    {
        phase: 'Render',
        product: 'Components',
        icon: 'laptop',
        title: 'Ship a typed React screen',
        description: 'Generated TypeScript proxies and Components remove the hand-written API client and form plumbing.',
        href: '/components/',
        cta: 'Browse Components',
        accent: '#a78bfa',
    },
    {
        phase: 'Operate',
        product: 'CLI + AI',
        icon: 'rocket',
        title: 'Inspect the running system',
        description: 'Use the CLI, Workbench, and AI tooling to browse events, replay projections, and diagnose observers.',
        href: '/ai-native-development/',
        cta: 'Use AI tooling',
        accent: '#fb7185',
    },
];
---

<section class="stack-journey not-content" aria-labelledby="stack-journey-title">
    <div class="stack-journey__intro">
        <p class="stack-journey__eyebrow">{eyebrow}</p>
        <h2 id="stack-journey-title">{title}</h2>
        <p>{intro}</p>
    </div>

    <div class="stack-journey__layout">
        <ol class="stack-journey__steps">
            {steps.map((step, index) => (
                <li class="stack-journey__step" style={`--step-accent: ${step.accent}`}>
                    <a href={step.href} class="stack-journey__step-link">
                        <span class="stack-journey__marker" aria-hidden="true">
                            <span>{String(index + 1).padStart(2, '0')}</span>
                            <Icon name={step.icon} size="1.05rem" />
                        </span>
                        <span class="stack-journey__copy">
                            <span class="stack-journey__meta">{step.phase} / {step.product}</span>
                            <strong>{step.title}</strong>
                            <span>{step.description}</span>
                            <span class="stack-journey__cta">
                                {step.cta}
                                <Icon name="right-arrow" size="0.8rem" />
                            </span>
                        </span>
                    </a>
                </li>
            ))}
        </ol>

        <div class="stack-journey__preview" aria-hidden="true">
            <div class="stack-journey__window">
                <div class="stack-journey__bar">
                    <span></span>
                    <span></span>
                    <span></span>
                </div>

                <div class="stack-journey__canvas">
                    <div class="stack-journey__node stack-journey__node--model">
                        <span>Studio model</span>
                        <strong>Register author</strong>
                        <small>Command -> Event -> Read model</small>
                    </div>

                    <div class="stack-journey__split">
                        <div class="stack-journey__node stack-journey__node--code">
                            <span>C# slice</span>
                            <code>[Command] RegisterAuthor</code>
                            <code>AuthorRegistered</code>
                        </div>
                        <div class="stack-journey__node stack-journey__node--proxy">
                            <span>Generated proxy</span>
                            <code>RegisterAuthor.execute()</code>
                            <code>AllAuthors.use()</code>
                        </div>
                    </div>

                    <div class="stack-journey__flow">
                        <span>fact</span>
                        <span>projection</span>
                        <span>live query</span>
                    </div>

                    <div class="stack-journey__node stack-journey__node--screen">
                        <span>React screen</span>
                        <strong>Authors update live</strong>
                        <small>No API client to keep in sync.</small>
                    </div>

                    <div class="stack-journey__terminal">
                        <span class="stack-journey__terminal-title">operate</span>
                        <code>$ cratis chronicle observers list</code>
                        <code>$ cratis chronicle projections replay</code>
                    </div>

                    <div class="stack-journey__ai">AI</div>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .stack-journey {
        --journey-surface: color-mix(in srgb, var(--sl-color-bg) 92%, var(--sl-color-accent-low));
        --journey-surface-strong: color-mix(in srgb, var(--sl-color-gray-6) 78%, var(--sl-color-bg));
        --journey-border: color-mix(in srgb, var(--sl-color-accent) 18%, var(--sl-color-gray-5));
        --journey-text-muted: var(--sl-color-gray-2);
        position: relative;
        overflow: hidden;
        margin: 2rem 0 2.75rem;
        padding: 1.25rem;
        border: 1px solid var(--journey-border);
        border-radius: 0.75rem;
        background:
            radial-gradient(46rem 28rem at 86% 8%, color-mix(in srgb, #38bdf8 12%, transparent), transparent 70%),
            radial-gradient(36rem 24rem at 4% 92%, color-mix(in srgb, #4ade80 10%, transparent), transparent 72%),
            linear-gradient(135deg, var(--journey-surface), color-mix(in srgb, var(--sl-color-bg) 96%, #0f172a));
        box-shadow:
            inset 0 1px 0 color-mix(in srgb, var(--sl-color-white) 5%, transparent),
            0 20px 52px -36px color-mix(in srgb, var(--sl-color-accent) 65%, transparent);
    }

    :global([data-theme='light']) .stack-journey {
        --journey-surface: color-mix(in srgb, var(--sl-color-bg) 96%, var(--sl-color-accent-low));
        --journey-surface-strong: color-mix(in srgb, var(--sl-color-gray-7, #fff) 82%, var(--sl-color-bg));
        --journey-text-muted: var(--sl-color-gray-2);
        background:
            radial-gradient(46rem 28rem at 86% 8%, color-mix(in srgb, #0284c7 9%, transparent), transparent 70%),
            radial-gradient(36rem 24rem at 4% 92%, color-mix(in srgb, #16a34a 7%, transparent), transparent 72%),
            linear-gradient(135deg, var(--journey-surface), var(--sl-color-bg));
    }

    .stack-journey__intro {
        max-width: 46rem;
        margin-bottom: 1.25rem;
    }

    .stack-journey__eyebrow {
        margin: 0 0 0.35rem;
        color: var(--sl-color-accent-high);
        font-size: var(--sl-text-sm);
        font-weight: 700;
        letter-spacing: 0;
        text-transform: uppercase;
    }

    .stack-journey__intro h2 {
        margin: 0;
        color: var(--sl-color-white);
        font-size: 2rem;
        line-height: 1.12;
        letter-spacing: 0;
    }

    .stack-journey__intro p:last-child {
        margin: 0.75rem 0 0;
        color: var(--journey-text-muted);
        font-size: var(--sl-text-base);
        line-height: 1.65;
    }

    .stack-journey__layout {
        display: grid;
        gap: 1.25rem;
    }

    .stack-journey__steps {
        position: relative;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .stack-journey__steps::before {
        content: '';
        position: absolute;
        inset: 1.8rem auto 1.8rem 1.35rem;
        width: 2px;
        border-radius: 999px;
        background: linear-gradient(180deg, #f59e0b, #38bdf8, #4ade80, #a78bfa, #fb7185);
        opacity: 0.5;
    }

    .stack-journey__step {
        position: relative;
        margin: 0;
    }

    .stack-journey__step-link {
        display: grid;
        grid-template-columns: 2.7rem minmax(0, 1fr);
        gap: 0.85rem;
        align-items: start;
        padding: 0.75rem;
        border: 1px solid transparent;
        border-radius: 0.5rem;
        color: var(--sl-color-text);
        text-decoration: none;
        transition: background-color 0.18s ease, border-color 0.18s ease, transform 0.18s ease;
    }

    .stack-journey__step-link:hover,
    .stack-journey__step-link:focus-visible {
        border-color: color-mix(in srgb, var(--step-accent) 42%, transparent);
        background: color-mix(in srgb, var(--step-accent) 9%, transparent);
        transform: translateX(2px);
    }

    .stack-journey__step-link:focus-visible {
        outline: 2px solid var(--sl-color-text);
        outline-offset: 2px;
    }

    .stack-journey__marker {
        position: relative;
        z-index: 1;
        display: grid;
        place-items: center;
        width: 2.7rem;
        height: 2.7rem;
        border: 1px solid color-mix(in srgb, var(--step-accent) 45%, var(--sl-color-gray-5));
        border-radius: 999px;
        background: color-mix(in srgb, var(--step-accent) 14%, var(--sl-color-bg));
        color: color-mix(in srgb, var(--step-accent) 84%, var(--sl-color-white));
        box-shadow: 0 0 0 5px color-mix(in srgb, var(--sl-color-bg) 76%, transparent);
    }

    .stack-journey__marker span {
        position: absolute;
        inset-block-start: -0.3rem;
        inset-inline-end: -0.25rem;
        min-width: 1.15rem;
        padding: 0.05rem 0.25rem;
        border-radius: 999px;
        background: var(--step-accent);
        color: #06111f;
        font-size: 0.65rem;
        font-weight: 800;
        line-height: 1.3;
        text-align: center;
    }

    .stack-journey__copy {
        display: flex;
        min-width: 0;
        flex-direction: column;
        gap: 0.25rem;
    }

    .stack-journey__meta {
        color: color-mix(in srgb, var(--step-accent) 78%, var(--sl-color-white));
        font-size: var(--sl-text-xs);
        font-weight: 700;
        text-transform: uppercase;
    }

    .stack-journey__copy strong {
        color: var(--sl-color-white);
        font-size: var(--sl-text-lg);
        line-height: 1.25;
    }

    .stack-journey__copy > span:not(.stack-journey__meta):not(.stack-journey__cta) {
        color: var(--journey-text-muted);
        font-size: var(--sl-text-sm);
        line-height: 1.5;
    }

    .stack-journey__cta {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        width: fit-content;
        margin-top: 0.25rem;
        color: color-mix(in srgb, var(--step-accent) 72%, var(--sl-color-white));
        font-size: var(--sl-text-sm);
        font-weight: 700;
        transition: gap 0.18s ease;
    }

    .stack-journey__step-link:hover .stack-journey__cta,
    .stack-journey__step-link:focus-visible .stack-journey__cta {
        gap: 0.6rem;
    }

    .stack-journey__preview {
        min-width: 0;
    }

    .stack-journey__window {
        overflow: hidden;
        border: 1px solid color-mix(in srgb, var(--sl-color-accent) 22%, var(--sl-color-gray-5));
        border-radius: 0.55rem;
        background:
            linear-gradient(180deg, color-mix(in srgb, var(--sl-color-gray-6) 70%, transparent), transparent),
            color-mix(in srgb, var(--sl-color-bg) 86%, #020617);
        box-shadow:
            inset 0 1px 0 color-mix(in srgb, var(--sl-color-white) 6%, transparent),
            0 18px 45px -32px rgb(0 0 0 / 0.9);
    }

    .stack-journey__bar {
        display: flex;
        gap: 0.4rem;
        align-items: center;
        min-height: 2rem;
        padding-inline: 0.85rem;
        border-bottom: 1px solid color-mix(in srgb, var(--sl-color-gray-5) 72%, transparent);
        background: color-mix(in srgb, var(--sl-color-bg) 92%, #020617);
    }

    .stack-journey__bar span {
        width: 0.6rem;
        height: 0.6rem;
        border-radius: 999px;
        background: var(--sl-color-gray-4);
    }

    .stack-journey__bar span:nth-child(1) { background: #fb7185; }
    .stack-journey__bar span:nth-child(2) { background: #f59e0b; }
    .stack-journey__bar span:nth-child(3) { background: #4ade80; }

    .stack-journey__canvas {
        position: relative;
        display: grid;
        gap: 0.85rem;
        padding: 1rem;
        background-image:
            linear-gradient(color-mix(in srgb, var(--sl-color-accent) 6%, transparent) 1px, transparent 1px),
            linear-gradient(90deg, color-mix(in srgb, var(--sl-color-accent) 6%, transparent) 1px, transparent 1px);
        background-size: 2.5rem 2.5rem;
    }

    .stack-journey__node,
    .stack-journey__terminal {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        min-width: 0;
        padding: 0.85rem;
        border: 1px solid color-mix(in srgb, var(--node-accent) 42%, transparent);
        border-radius: 0.5rem;
        background:
            radial-gradient(24rem 12rem at 100% 0%, color-mix(in srgb, var(--node-accent) 13%, transparent), transparent 64%),
            color-mix(in srgb, var(--sl-color-gray-6) 72%, var(--sl-color-bg));
        box-shadow: inset 0 1px 0 color-mix(in srgb, var(--sl-color-white) 5%, transparent);
    }

    .stack-journey__node span,
    .stack-journey__terminal-title {
        color: color-mix(in srgb, var(--node-accent) 76%, var(--sl-color-white));
        font-size: var(--sl-text-xs);
        font-weight: 800;
        text-transform: uppercase;
    }

    .stack-journey__node strong {
        color: var(--sl-color-white);
        line-height: 1.2;
    }

    .stack-journey__node small {
        color: var(--journey-text-muted);
        font-size: var(--sl-text-xs);
        line-height: 1.45;
    }

    .stack-journey__node code,
    .stack-journey__terminal code {
        overflow: hidden;
        color: var(--sl-color-gray-1);
        font-family: var(--sl-font-mono);
        font-size: 0.76rem;
        line-height: 1.45;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    .stack-journey__node--model { --node-accent: #f59e0b; }
    .stack-journey__node--code { --node-accent: #38bdf8; }
    .stack-journey__node--proxy { --node-accent: #a78bfa; }
    .stack-journey__node--screen { --node-accent: #4ade80; }

    .stack-journey__split {
        display: grid;
        gap: 0.85rem;
    }

    .stack-journey__flow {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.45rem;
    }

    .stack-journey__flow span {
        min-width: 0;
        padding: 0.45rem 0.55rem;
        border: 1px solid color-mix(in srgb, var(--sl-color-accent) 28%, transparent);
        border-radius: 999px;
        background: color-mix(in srgb, var(--sl-color-accent) 10%, transparent);
        color: var(--sl-color-accent-high);
        font-size: var(--sl-text-xs);
        font-weight: 800;
        text-align: center;
        text-transform: uppercase;
    }

    .stack-journey__terminal {
        --node-accent: #fb7185;
        background:
            radial-gradient(18rem 8rem at 100% 0%, color-mix(in srgb, #fb7185 12%, transparent), transparent 72%),
            #07111f;
    }

    .stack-journey__ai {
        position: absolute;
        z-index: 2;
        inset-block-start: 0.85rem;
        inset-inline-end: 0.85rem;
        display: grid;
        place-items: center;
        width: 2.65rem;
        height: 2.65rem;
        border: 1px solid color-mix(in srgb, #fb7185 55%, transparent);
        border-radius: 999px;
        background:
            radial-gradient(circle at 35% 25%, color-mix(in srgb, #fff 26%, transparent), transparent 34%),
            color-mix(in srgb, #fb7185 24%, var(--sl-color-bg));
        color: color-mix(in srgb, #fb7185 76%, var(--sl-color-white));
        font-size: 0.85rem;
        font-weight: 900;
        box-shadow: 0 0 32px color-mix(in srgb, #fb7185 24%, transparent);
    }

    @media (min-width: 40rem) {
        .stack-journey {
            padding: 1.5rem;
        }

        .stack-journey__split {
            grid-template-columns: repeat(2, minmax(0, 1fr));
        }
    }

    @media (min-width: 62rem) {
        .stack-journey__layout {
            grid-template-columns: minmax(0, 0.95fr) minmax(22rem, 1.05fr);
            align-items: center;
        }

        .stack-journey__preview {
            position: sticky;
            top: 5rem;
        }
    }

    @media (max-width: 39.99rem) {
        .stack-journey {
            margin-inline: -0.25rem;
            padding: 1rem;
        }

        .stack-journey__intro h2 {
            font-size: 1.45rem;
        }

        .stack-journey__step-link {
            grid-template-columns: 2.35rem minmax(0, 1fr);
            gap: 0.7rem;
            padding: 0.65rem 0.35rem;
        }

        .stack-journey__marker {
            width: 2.35rem;
            height: 2.35rem;
        }

        .stack-journey__steps::before {
            inset-inline-start: 1.16rem;
        }

        .stack-journey__flow {
            grid-template-columns: 1fr;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .stack-journey__step-link,
        .stack-journey__cta {
            transition: none;
        }

        .stack-journey__step-link:hover,
        .stack-journey__step-link:focus-visible {
            transform: none;
        }
    }
</style>
